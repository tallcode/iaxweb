HOST=0.0.0.0
PORT=3000
NATS_SERVERS=nats://127.0.0.1:4222
NATS_SUBJECT_ROOT=iaxmon.nodes

# Gateway 每 15 秒按节点上报当前 /audio WebSocket 数量，无需额外配置。

ALLMON3_BASE_URL=http://172.16.211.199/allmon3/
ALLMON3_REFRESH_INTERVAL_MS=30000
ALLMON3_REQUEST_TIMEOUT_MS=10000

# Choose either username/password or token authentication.
# NATS_USERNAME=iaxweb
# NATS_PASSWORD=change-me
# NATS_TOKEN=change-me
